# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

VITE_DRIVE_FILE_ID=replace_with_your_google_drive_file_id
VITE_DRIVE_API_KEY=replace_with_your_google_drive_api_key
VITE_APP_NAME=Smart Quote Generator

# Auth — SHA-256 hash of your chosen passphrase (never store plain text)
# Generate: node -e "const c=require('crypto');console.log(c.createHash('sha256').update('YOUR_PASS').digest('hex'))"
# Default below is hash of "changeme" — REPLACE before deploying
VITE_APP_PASSPHRASE_HASH=057ba03d6c44104863dc7361fe4578965d1887360f90a0895882e58a6248fc86
